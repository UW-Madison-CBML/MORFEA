# export_cebra.sub
   
docker_image = jenslundsgaard/ivf-training:v1.7
universe = docker
# Specify your executable (single binary or a script that runs several
#  commands) and arguments to be passed to jobs. 
#  $(Process) will be a integer number for each job, starting with "0"
#  and increasing for the relevant number of jobs.
shell = ./export_cebra.sh $(model)
   		
# Specify the name of the log, standard error, and standard output (or
# "screen output") files. Wherever you see $(Cluster), HTCondor will insert the 
#  queue number assigned to this set of jobs at the time of submission.
log = export_cebra_$(Cluster)_$(Process).log
error =  export_cebra_$(Cluster)_$(Process).err
output = export_cebra_$(Cluster)_$(Process).out
should_transfer_files = YES
when_to_transfer_output = ON_EXIT_OR_EVICT
Requirements = (Target.HasCHTCStaging == true)
#require_gpus = (DriverVersion >= 10.1)
# Transfer our executable script
transfer_output_remaps = "cebra_latents.tar.gz =  file:///staging/groups/bhaskar_group/ivf/cebra_latents.tar.gz;"
transfer_input_files = export_cebra.sh, export_cebra.py, ../training/dataset_ivf_embryo.py, file:///staging/groups/bhaskar_group/ivf/index_embryo.csv, ../api_keys.txt,  file:///staging/groups/bhaskar_group/ivf/embryo_dataset_grades.csv,file:///staging/groups/bhaskar_group/ivf/cebra_latents.tar.gz, file:///staging/groups/bhaskar_group/ivf/embryo_dataset_annotations.tar.gz, file:///staging/groups/bhaskar_group/ivf/latents.tar.gz


+WantGPULab = true
+GPUJobLength = "short"
gpus_minimum_capability = 7.0
#Requirements = (Machine == "bhaskargpu4000.chtc.wisc.edu") && (DriverVersion == "12.8") && (DeviceName == "NVIDIA H200")
 
+GPUModel = "NVIDIA H200"
transfer_output_files = cebra_latents.tar.gz
# Requirements (e.g., operating system) your job needs, what amount of
# compute resources each job will need on the computer where it runs.
request_cpus = 16
request_memory = 64GB
request_disk = 80GB
request_gpus = 1


#queue models from get_latents.txt
queue model from (ver12-2026-04-06)
