# train_and_eval_cebra.sub
   
container_image =docker://jenslundsgaard/ivf-training:v1.6

#docker_image = pytorch/pytorch:2.9.0-cuda12.8-cudnn9-runtime
#docker_image = pytorch/pytorch:1.1.0-cuda10.0-cudnn7.5-runtime
universe = container
# Specify your executable (single binary or a script that runs several
#  commands) and arguments to be passed to jobs. 
#  $(Process) will be a integer number for each job, starting with "0"
#  and increasing for the relevant number of jobs.
shell = ./train_and_eval_cebra.sh $(model)
   		
# Specify the name of the log, standard error, and standard output (or
# "screen output") files. Wherever you see $(Cluster), HTCondor will insert the 
#  queue number assigned to this set of jobs at the time of submission.
log = train_and_eval_cebra_$(Cluster)_$(Process).log
error = train_and_eval_cebra_$(Cluster)_$(Process).err
output = train_and_eval_cebra_$(Cluster)_$(Process).out
should_transfer_files = YES
when_to_transfer_output = ON_EXIT_OR_EVICT
Requirements = (Target.HasCHTCStaging == true)
#require_gpus = (DriverVersion >= 10.1)
# Transfer our executable script
transfer_input_files = train_and_eval_cebra.sh, train_and_eval_cebra.py, api_keys.txt, file:///staging/groups/bhaskar_group/ivf/embryo_dataset.tar.gz, file:///staging/groups/bhaskar_group/ivf/index.csv, build_index.py, raffael_model.py, raffael_conv_lstm.py, raffael_losses.py, file:///staging/groups/bhaskar_group/ivf/embryo_dataset_grades.csv, dataset_ivf_embryo.py ,file:///staging/groups/bhaskar_group/ivf/index_embryo.csv, file:///staging/groups/bhaskar_group/ivf/embryo_dataset_grades.csv, file:///staging/groups/bhaskar_group/ivf/embryo_dataset_annotations.tar.gz, geometric_features.py
gpus_minimum_capability = 7.0
requirements= Machine=="bhaskargpu4000.chtc.wisc.edu"
transfer_output_files = cebra_plots.tar.gz, $(model)_cebra_time_model.pt
transfer_output_remaps = "cebra_plots.tar.gz = $(model)_cebra_plots.tar.gz;"
+GPUModel = "NVIDIA H200"
#transfer_output_files = model_weights.pth 
# Requirements (e.g., operating system) your job needs, what amount of
# compute resources each job will need on the computer where it runs.
request_cpus = 8
request_memory = 64GB
request_disk = 80GB
request_gpus = 1


queue model from (
notemp-2026-03-12
nolstm-2026-03-12
control-2026-03-12
)
